# ===============================
# Qwen/OpenAI 兼容接口配置示例
# 复制本文件为 .env 后按需填写
# ===============================

# 必填：Qwen 平台 API Key
QWEN_API_KEY=your_qwen_api_key_here

# 必填：OpenAI 兼容接口 Base URL（示例为 DashScope 兼容地址）
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 可选：模型名称，未配置时默认 qwen-max
QWEN_MODEL=qwen-max
